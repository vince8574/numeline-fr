{
  "expo": {
    "name": "numelineFR",
    "slug": "numelineFR",
    "scheme": "numelineFR",
    "version": "1.0.19",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo_numelineFR.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1F1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.numelinefr.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "jsEngine": "jsc",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "L'appareil photo est utilisé pour scanner les codes-barres et les numéros de lot de vos produits alimentaires.",
        "NSPhotoLibraryUsageDescription": "L'accès à vos photos permet d'importer une image de produit à analyser.",
        "NSPhotoLibraryAddUsageDescription": "L'accès à vos photos permet d'enregistrer les images et exports générés par l'application.",
        "NSSpeechRecognitionUsageDescription": "La reconnaissance vocale est utilisée pour les commandes d'accessibilité pendant le scan.",
        "NSMicrophoneUsageDescription": "Nous avons besoin du microphone pour les commandes vocales d'accessibilité (dire \"photo\" pour capturer, \"flash\" pour la lampe).",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "40"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1F1F"
      },
      "package": "com.numeline.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "notification": {
        "icon": "./assets/adaptive-icon.png",
        "color": "#0BAE86"
      },
      "versionCode": 53
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "./plugins/withModularHeaders",
      "./plugins/withFirebaseSwift",
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nous avons besoin d'accéder à votre appareil photo pour scanner les emballages."
        }
      ],
      [
        "expo-notifications",
        {
          "mode": "production"
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.577892941568-nuu80fn9les9h37u1tcl5bdh30cgc98d"
        }
      ],
      "expo-localization",
      "expo-font",
      "react-native-iap",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Nous avons besoin du microphone pour les commandes vocales d'accessibilité (dire \"photo\" pour capturer, \"flash\" pour la lampe).",
          "speechRecognitionPermission": "La reconnaissance vocale est utilisée pour les commandes d'accessibilité pendant le scan.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "vision": {
        "endpoint": "https://europe-west1-eatsok-6d19f.cloudfunctions.net/ocrVision"
      },
      "claude": {
        "endpoint": "https://europe-west1-eatsok-6d19f.cloudfunctions.net/ocrClaude"
      },
      "eas": {
        "projectId": "410121d2-8d46-4292-b5dd-40a688a56243"
      }
    }
  }
}
