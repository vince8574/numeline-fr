{
  "expo": {
    "name": "numelineFR",
    "slug": "numelineFR",
    "scheme": "numelineFR",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1F1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.numelinefr.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1F1F"
      },
      "package": "com.numelinefr.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "notification": {
        "icon": "./assets/adaptive-icon.png",
        "color": "#0BAE86"
      }
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Nous avons besoin d'accéder à votre appareil photo pour scanner les emballages."
        }
      ],
      [
        "expo-notifications",
        {
          "mode": "production"
        }
      ],
      "expo-localization",
      "expo-font",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "vision": {
        "endpoint": "https://europe-west1-eatsok-6d19f.cloudfunctions.net/ocrVision"
      },
      "eas": {
        "projectId": "410121d2-8d46-4292-b5dd-40a688a56243"
      }
    }
  }
}
