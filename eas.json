{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "env": {
        "NODE_ENV": "production"
      },
      "node": "20.19.4",
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "ios": {
        "buildConfiguration": "Release",
        "resourceClass": "m-medium",
        "image": "latest"
      }
    },
    "production-apk": {
      "autoIncrement": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production"
      },
      "node": "20.19.4",
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
